{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Titus Notes",
  "version": "0.1.2",
  "identifier": "com.notes-gr.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Titus Notes",
        "width": 1600,
        "height": 900
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/files/audio/*", "$APPDATA/files/audio/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "ZFc1MGNuVnpkR1ZrSUdOdmJXMWxiblE2SUcxcGJtbHphV2R1SUhCMVlteHBZeUJyWlhrNklEWTNSamRGUkVJMFFqWkRRMEk1TjBFS1VsZFNOblZqZVRKMFR6TXpXamxwSzNoNVRteG5kbTVYSzJneVZrMUhNVElyTTBGelRVNUlNa0YwWkhGSFZWSmlURFZQYm5NMmNsQUs=",
      "endpoints": [
        "https://github.com/titogarrido/titus-notes-ov/releases/latest/download/latest.json"
      ]
    }
  }
}
