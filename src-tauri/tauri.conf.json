{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Titus Notes",
  "version": "2.0.3",
  "identifier": "com.notes-gr.titus-notes",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Titus Notes",
        "width": 1600,
        "height": 900
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: asset: blob: https: http: https://asset.localhost; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost http://localhost:* http://127.0.0.1:* https:; media-src 'self' asset: blob: https://asset.localhost; object-src 'none'; frame-ancestors 'none'",
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/files/audio/*", "$APPDATA/files/audio/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IERBQzRBRkFGM0VCNDg3ODcKUldTSGg3UStyNi9FMm9iYkd5VkgvTFdJK1FJeVF3RDJyajZmcGFEVEhpaTZvMU5yU1JsUDZWTU4K",
      "endpoints": [
        "https://github.com/titogarrido/titus-notes-ov/releases/latest/download/latest.json"
      ]
    }
  }
}
